{
  "name": "squared2",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=dist/main.js --watch --servedir=.",
    "build": "esbuild src/main.ts --bundle --outfile=dist/main.js --minify",
    "format": "prettier --write src/**/*.ts",
    "check": "prettier --check src/**/*.ts"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0"
  }
}
